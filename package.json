{
  "name": "context-chest",
  "version": "1.0.0",
  "description": "Sync & Connect API for Context Chest",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "jest",
    "test:e2e": "jest src/tests/e2e.test.ts",
    "seed": "ts-node prisma/seed.ts",
    "db:seed": "prisma db seed",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.425.0",
    "@cloudflare/opaque-ts": "^0.7.5",
    "@fastify/cors": "^8.4.1",
    "@fastify/jwt": "^7.2.3",
    "@fastify/swagger": "^8.12.1",
    "@fastify/swagger-ui": "^1.10.1",
    "@prisma/client": "^5.7.1",
    "fastify": "^4.24.3",
    "prom-client": "^14.2.0",
    "rate-limiter-flexible": "^3.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.5",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prisma": "^5.7.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
} 