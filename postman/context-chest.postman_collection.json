{
  "info": {
    "name": "Context Chest API",
    "description": "Sync & Connect API for Context Chest",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{demo_email}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/auth/register",
              "host": ["{{base_url}}"],
              "path": ["v1", "auth", "register"]
            }
          }
        },
        {
          "name": "Register Finish",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{demo_email}}\",\n  \"msg\": \"{{registration_msg}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/auth/register/finish",
              "host": ["{{base_url}}"],
              "path": ["v1", "auth", "register", "finish"]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{demo_email}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["v1", "auth", "login"]
            }
          }
        },
        {
          "name": "Login Finish",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{demo_email}}\",\n  \"msg\": \"{{login_msg}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/auth/login/finish",
              "host": ["{{base_url}}"],
              "path": ["v1", "auth", "login", "finish"]
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["v1", "auth", "refresh"]
            }
          }
        }
      ]
    },
    {
      "name": "Vault",
      "item": [
        {
          "name": "Upload Blob",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/octet-stream"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{session_token}}"
              },
              {
                "key": "X-BLOB-SHA256",
                "value": "{{blob_sha256}}"
              }
            ],
            "body": {
              "mode": "file",
              "file": {
                "src": "{{blob_file}}"
              }
            },
            "url": {
              "raw": "{{base_url}}/v1/vault/blob",
              "host": ["{{base_url}}"],
              "path": ["v1", "vault", "blob"]
            }
          }
        },
        {
          "name": "Download Blob",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{session_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/vault/blob",
              "host": ["{{base_url}}"],
              "path": ["v1", "vault", "blob"]
            }
          }
        }
      ]
    },
    {
      "name": "Connect",
      "item": [
        {
          "name": "Authorize",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{session_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"client_id\": \"{{client_id}}\",\n  \"requested_scopes\": [\"vault.read\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/connect/authorize",
              "host": ["{{base_url}}"],
              "path": ["v1", "connect", "authorize"]
            }
          }
        },
        {
          "name": "Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"consent_code\": \"{{consent_code}}\",\n  \"client_secret\": \"{{client_secret}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/connect/token",
              "host": ["{{base_url}}"],
              "path": ["v1", "connect", "token"]
            }
          }
        },
        {
          "name": "Introspect",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{grant_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/connect/introspect",
              "host": ["{{base_url}}"],
              "path": ["v1", "connect", "introspect"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000"
    },
    {
      "key": "demo_email",
      "value": "demo@example.com"
    },
    {
      "key": "client_id",
      "value": "demo_app"
    },
    {
      "key": "client_secret",
      "value": "demo_secret"
    }
  ]
} 