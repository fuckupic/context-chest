{
  "id": "context-chest",
  "name": "Context Chest",
  "description": "Encrypted persistent memory for AI agents. AES-256-GCM client-side encryption — the server never sees your data.",
  "version": "0.1.0",
  "kind": "memory",
  "configSchema": {
    "type": "object",
    "properties": {
      "apiUrl": {
        "type": "string",
        "description": "Context Chest API URL",
        "default": "https://api-production-e2cd6.up.railway.app"
      },
      "apiToken": {
        "type": "string",
        "description": "JWT token from 'npx context-chest-mcp login'"
      },
      "exportKey": {
        "type": "string",
        "description": "Export key from 'npx context-chest-mcp login' (shown in credentials.json)"
      },
      "userId": {
        "type": "string",
        "description": "User ID from credentials.json"
      }
    },
    "required": ["apiToken", "exportKey", "userId"],
    "additionalProperties": false
  },
  "uiHints": {
    "apiToken": {
      "label": "API Token",
      "placeholder": "eyJhbG...",
      "sensitive": true
    },
    "exportKey": {
      "label": "Export Key",
      "placeholder": "hex string from credentials.json",
      "sensitive": true
    },
    "userId": {
      "label": "User ID",
      "placeholder": "uuid from credentials.json"
    },
    "apiUrl": {
      "label": "API URL (optional)",
      "placeholder": "https://api-production-e2cd6.up.railway.app"
    }
  }
}
